{
  "name": "texlens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Mathpix-like desktop OCR for LaTeX documents using PaddleOCR-VL via FastDeploy.",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "NO_STRIP=1 sh scripts/tauri-build-appimage.sh",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "e2e": "playwright test",
    "sidecar:dev": "uv run --project sidecar texlens-sidecar",
    "sidecar:test": "uv run --project sidecar pytest sidecar/tests",
    "ocr:bench": "uv run --project sidecar python -m texlens_sidecar.bench",
    "perf:record": "uv run --project sidecar python -m texlens_sidecar.perf_record",
    "verify": "pnpm lint && pnpm test && pnpm sidecar:test && pnpm ocr:bench && pnpm perf:record && pnpm tauri:build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "lucide-react": "^0.469.0",
    "monaco-editor": "^0.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.4"
}
